name: ChromeOS-Hatch-Tailscale-Final

on:
  workflow_dispatch:

jobs:
  build-and-run:
    runs-on: ubuntu-latest
    steps:
      - name: 1. Maximize Server Space
        run: |
          sudo rm -rf /usr/share/dotnet /usr/local/lib/android /opt/ghc
          sudo docker image prune -a -f

      - name: 2. Install Dependencies
        run: |
          sudo apt update
          sudo apt install -y unzip tar pv jq qemu-kvm qemu-utils

      - name: 3. Download Files (Safe Method)
        run: |
          # تحميل ملف Hatch Recovery
          curl -L "https://drive.google.com/uc?export=download&id=1VuhGxGRVrIVqKN2l0AZE0tzLh03VbIou" -o hatch.zip
          
          # تحميل ملف Brunch الذي رفعته أنت (باستخدام الـ ID الخاص بك)
          curl -L "https://drive.google.com/uc?export=download&id=1amBG8ijogsOWqJKu0kSud27ZVb0wXPpa" -o brunch.tar.gz

      - name: 4. Extract and Build
        run: |
          # فك ضغط Brunch مع التحقق من الصيغة
          file brunch.tar.gz
          tar -xvf brunch.tar.gz
          
          # فك ضغط نسخة النظام
          unzip hatch.zip
          
          # بناء الصورة
          sudo bash chromeos-install.sh -src *.bin -dst chromeos.img

      - name: 5. Connect to Tailscale
        uses: tailscale/github-action@v2
        with:
          authkey: ${{ secrets.TS_AUTHKEY }}

      - name: 6. Run ChromeOS
        run: |
          docker run -d --name chromeos --device /dev/kvm -p 3389:3389 \
          -v $(pwd)/chromeos.img:/image/chromeos.img \
          -e RAM=7 -e CORES=2 sickcodes/docker-chromeos:latest

      - name: 7. Get IP and Keep Alive
        run: |
          echo "===================================================="
          echo "✅ النظام يعمل الآن على شبكة Tailscale الخاصة بك!"
          echo "🔗 استخدم عنوان IP الخاص بالـ Runner للاتصال عبر RDP."
          tailscale ip -4
          echo "===================================================="
          while true; do sleep 300; done
